"""雪球讨论 — 订单与基本面信息监控

拉取指定股票当天所有雪球讨论，通过 LLM 筛选出包含企业订单
（商品销售、合同签订、客户中标等）和基本面（营收、利润、产能、
政策等）的帖子，过滤掉纯炒股情绪/技术面讨论，最终生成一份
结构化总结文档。

用法:
    python -m src.downloader.xueqiu_order_monitor --codes 600519,000858
    python -m src.downloader.xueqiu_order_monitor --codes 600519 --llm-api-key sk-xxx
"""

import argparse
import csv
import json
import logging
import os
import re
import sys
import time
from datetime import datetime, date
from pathlib import Path

import requests
from DrissionPage import ChromiumPage, ChromiumOptions

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
)
log = logging.getLogger(__name__)


def _load_env_file():
    """从项目根目录 .env 文件加载环境变量 (不覆盖已有的)"""
    env_path = Path(__file__).resolve().parents[2] / ".env"
    if not env_path.exists():
        return
    with open(env_path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, _, value = line.partition("=")
            key, value = key.strip(), value.strip()
            if key and key not in os.environ:
                os.environ[key] = value


_load_env_file()

# ── 默认 LLM 配置 ─────────────────────────────────────────
DEFAULT_LLM_BASE_URL = "https://coding.dashscope.aliyuncs.com/v1"
DEFAULT_LLM_MODEL = "qwen3.6-plus"

# ── 雪球 API ───────────────────────────────────────────────
XUEQIU_HOME = "https://xueqiu.com"
XUEQIU_STOCK_COMMENT_URL = "https://xueqiu.com/query/v1/symbol/search/status.json"

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/120.0.0.0 Safari/537.36"
    ),
    "Referer": "https://xueqiu.com/",
}


def _to_xueqiu_symbol(code: str) -> str:
    """将 A 股代码转为雪球格式, 如 600519 -> SH600519"""
    code = code.strip()
    if code.startswith(("SH", "SZ", "sh", "sz")):
        return code.upper()
    if code.startswith(("6", "9")):
        return f"SH{code}"
    elif code.startswith(("0", "3", "2")):
        return f"SZ{code}"
    return code.upper()


def _ts_to_str(ts) -> str:
    if ts is None:
        return ""
    try:
        return datetime.fromtimestamp(ts / 1000).strftime("%Y-%m-%d %H:%M:%S")
    except Exception:
        return str(ts)


def _ts_to_date(ts) -> date | None:
    if ts is None:
        return None
    try:
        return datetime.fromtimestamp(ts / 1000).date()
    except Exception:
        return None


def _clean_html(text: str) -> str:
    return re.sub(r"<[^>]+>", "", text) if text else ""


class XueqiuSession:
    """用 DrissionPage 管理雪球会话 (自动通过 WAF)"""

    # WAF / 限流响应关键词
    _WAF_KEYWORDS = ("Access Ver", "TIME: 20", "访问验证", "请完成验证", "Sorry, you")

    def __init__(self):
        self.page = None
        self._start_browser()

    def _start_browser(self):
        """启动浏览器并初始化雪球会话"""
        # 先关闭旧浏览器
        if self.page is not None:
            try:
                self.page.quit()
            except Exception:
                pass

        co = ChromiumOptions()
        co.set_browser_path("/usr/bin/chromium-browser")
        co.headless()
        co.set_argument("--no-sandbox")
        co.set_argument("--disable-dev-shm-usage")
        co.set_argument("--disable-gpu")
        log.info("启动浏览器并初始化雪球会话 ...")
        self.page = ChromiumPage(co)
        self._init_session()

    def _init_session(self):
        self.page.get(XUEQIU_HOME)
        time.sleep(5)
        log.info(f"雪球首页已加载: {self.page.title}")

    def refresh_session(self, cooldown: float = 30):
        """重新启动浏览器并获取新的 cookie/session"""
        log.warning(f"WAF/限流检测 — 冷却 {cooldown}s 后重新启动浏览器 ...")
        time.sleep(cooldown)
        self._start_browser()
        time.sleep(3)
        log.info("会话已刷新")

    def _get_body_prefix(self) -> str:
        """获取页面 body 前 200 字符 (用于 WAF 检测)"""
        try:
            return self.page.run_js("return document.body.innerText.substring(0, 200)") or ""
        except Exception:
            return ""

    def _is_waf_response(self, body_prefix: str = None) -> bool:
        """检测当前页面是否为 WAF/限流拦截页面"""
        if body_prefix is None:
            body_prefix = self._get_body_prefix()
        return any(kw in body_prefix for kw in self._WAF_KEYWORDS)

    def fetch_json(self, url: str, retries: int = 3) -> dict:
        """导航到 URL 并在浏览器内解析 JSON, 自动重试+退避+刷新会话"""
        last_err = None
        for attempt in range(retries + 1):
            try:
                self.page.get(url)
                time.sleep(2)

                # 先检测 body 前缀, WAF/限流返回非 JSON 文本
                body_prefix = self._get_body_prefix()
                if self._is_waf_response(body_prefix):
                    raise RuntimeError(f"WAF/限流拦截: {body_prefix[:60]}")

                data = self.page.run_js("return JSON.parse(document.body.innerText)")
                return data
            except Exception as e:
                last_err = e
                if attempt < retries:
                    # 指数退避: 5s → 30s → 60s, 最后两次带会话刷新
                    backoff = [5, 30, 60][min(attempt, 2)]
                    log.warning(f"fetch_json 失败 (第{attempt+1}次, 等{backoff}s): {e}")
                    if attempt == 0:
                        time.sleep(backoff)
                    else:
                        self.refresh_session(cooldown=backoff)
        raise last_err

    def close(self):
        try:
            self.page.quit()
        except Exception:
            pass


# ── 拉取当天所有讨论（分页） ─────────────────────────────────

def fetch_today_discussions(
    xq: XueqiuSession,
    symbol: str,
    page_size: int = 100,
    max_pages: int = 20,
    delay: float = 1.0,
) -> list[dict]:
    """分页拉取个股当天所有讨论"""
    today = date.today()
    all_posts = []
    page = 1

    while page <= max_pages:
        url = (
            f"{XUEQIU_STOCK_COMMENT_URL}?"
            f"symbol={symbol}&count={page_size}&comment=0&page={page}&sort=time"
        )
        try:
            data = xq.fetch_json(url)
        except Exception as e:
            log.warning(f"[{symbol}] 第 {page} 页请求失败: {e}")
            break

        statuses = data.get("list", [])
        if not statuses:
            break

        reached_yesterday = False
        for p in statuses:
            post_date = _ts_to_date(p.get("created_at"))
            if post_date is None:
                continue
            if post_date < today:
                reached_yesterday = True
                break
            if post_date == today:
                all_posts.append(p)

        if reached_yesterday:
            break

        page += 1
        if page <= max_pages:
            time.sleep(delay)

    log.info(f"[{symbol}] 当天共拉取 {len(all_posts)} 条讨论 (遍历 {page} 页)")
    return all_posts


def _parse_posts(posts: list[dict]) -> list[dict]:
    """将原始帖子解析为干净的结构"""
    parsed = []
    for p in posts:
        text = _clean_html(p.get("text", "") or "")
        title = _clean_html(p.get("title", "") or "")
        if not text and not title:
            continue
        parsed.append({
            "id": p.get("id"),
            "user": (p.get("user") or {}).get("screen_name", ""),
            "followers_count": (p.get("user") or {}).get("followers_count", 0),
            "created_at": _ts_to_str(p.get("created_at")),
            "title": title,
            "text": text[:2000],
            "retweet_count": p.get("retweet_count", 0),
            "reply_count": p.get("reply_count", 0),
            "like_count": p.get("like_count", 0),
        })
    return parsed


# ── LLM 调用 ──────────────────────────────────────────────

def _llm_call(
    base_url: str, model: str, api_key: str,
    system_prompt: str, user_msg: str,
    temperature: float = 0.1, timeout: int = 120,
    retries: int = 2,
) -> str:
    """通用 OpenAI 兼容 LLM 调用，返回 content 文本"""
    url = f"{base_url.rstrip('/')}/chat/completions"
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_msg},
        ],
        "temperature": temperature,
    }
    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"

    last_err = None
    for attempt in range(retries + 1):
        try:
            resp = requests.post(url, json=payload, headers=headers, timeout=timeout)
            resp.raise_for_status()
            result = resp.json()
            return result["choices"][0]["message"]["content"]
        except Exception as e:
            last_err = e
            if attempt < retries:
                wait = 5 * (attempt + 1)
                log.warning(f"LLM 调用失败 (第{attempt+1}次): {e}, {wait}s 后重试")
                time.sleep(wait)
    raise last_err


def _parse_json_from_llm(text: str) -> list:
    """从 LLM 回复中提取 JSON 数组"""
    text = text.strip()
    if text.startswith("```"):
        text = re.sub(r"^```\w*\n?", "", text)
        text = re.sub(r"\n?```$", "", text)
    try:
        obj = json.loads(text)
        return obj if isinstance(obj, list) else []
    except json.JSONDecodeError:
        return []


# ── 第一步: LLM 过滤 ─────────────────────────────────────

FILTER_SYSTEM_PROMPT = """\
你是一个上市公司信息筛选助手。你的任务是从雪球社区帖子中筛选出包含以下内容的帖子:

【需要保留的内容】
1. 企业订单信息: 商品销售订单、合同签订、中标公告、客户采购、出货量、交付进度等
2. 基本面信息: 营收、利润、毛利率、产能、产量、库存、价格变动、行业供需、政策影响、管理层变动、分红、并购等

【需要过滤掉的内容】
- 纯股票买卖操作讨论 (买入/卖出/加仓/止损等个人交易行为)
- 纯技术面分析 (K线、均线、MACD、支撑位等)
- 纯情绪发泄 (骂庄家、喊口号等)
- 与公司经营无关的闲聊

给你一组帖子 (编号 1~N)，请返回你认为相关的帖子编号列表。
只返回 JSON 数组，如 [1, 3, 7]。如果没有相关帖子，返回 []。"""


def llm_filter_posts(
    posts: list[dict],
    base_url: str, model: str, api_key: str,
    batch_size: int = 30,
) -> list[dict]:
    """用 LLM 过滤帖子, 只保留包含订单/基本面信息的"""
    if not posts:
        return []

    kept = []
    for start in range(0, len(posts), batch_size):
        batch = posts[start:start + batch_size]
        lines = []
        for i, p in enumerate(batch):
            idx = start + i + 1
            snippet = p["text"][:400].replace("\n", " ")
            title_part = f"标题: {p['title']} | " if p["title"] else ""
            lines.append(f"[{idx}] {title_part}{snippet}")

        user_msg = "\n\n".join(lines)
        log.info(f"LLM 过滤: 第 {start+1}~{start+len(batch)} 条 ...")

        try:
            reply = _llm_call(base_url, model, api_key, FILTER_SYSTEM_PROMPT, user_msg)
            selected_ids = _parse_json_from_llm(reply)
            for sid in selected_ids:
                if isinstance(sid, int) and 1 <= sid <= len(posts):
                    kept.append(posts[sid - 1])
        except Exception as e:
            log.warning(f"LLM 过滤失败 (batch {start}): {e}, 跳过此批次")

    log.info(f"LLM 过滤完成: {len(posts)} → {len(kept)} 条")
    return kept


# ── 第二步: LLM 总结 ─────────────────────────────────────

SUMMARY_SYSTEM_PROMPT = """\
你是一个上市公司情报分析师。给你一组从雪球社区筛选出的帖子，
这些帖子都包含企业订单信息或基本面消息。

请完成以下任务:
1. 按主题分类整理这些信息 (订单/合同、财务/业绩、产能/产量、行业/政策、其他基本面)
2. 对每个主题给出简洁的要点总结
3. 标注信息来源 (用户名)
4. 在最后给出一段综合评价: 这些信息整体偏利好还是利空, 关注重点是什么

输出格式为 Markdown, 层次清晰。"""


def llm_summarize(
    posts: list[dict],
    symbol: str,
    base_url: str, model: str, api_key: str,
) -> str:
    """用 LLM 对筛选后的帖子生成总结文档"""
    if not posts:
        return ""

    # 限制最多 30 条避免上下文过大超时
    use_posts = posts[:30]
    if len(posts) > 30:
        log.info(f"总结帖子过多 ({len(posts)} 条), 取前 30 条")

    lines = []
    for i, p in enumerate(use_posts, 1):
        user_info = f"{p['user']}"
        if p["followers_count"] > 1000:
            user_info += f" (粉丝 {p['followers_count']})"
        lines.append(
            f"[{i}] 用户: {user_info} | 时间: {p['created_at']}\n"
            f"    {p['text'][:500]}"
        )

    user_msg = f"股票: {symbol}\n日期: {date.today()}\n\n" + "\n\n".join(lines)

    log.info(f"LLM 生成总结, {len(posts)} 条帖子 ...")
    try:
        summary = _llm_call(
            base_url, model, api_key, SUMMARY_SYSTEM_PROMPT, user_msg,
            temperature=0.3, timeout=180,
        )
        return summary
    except Exception as e:
        log.error(f"LLM 总结失败: {e}")
        return ""


# ── 主流程 ─────────────────────────────────────────────────

def monitor_stock(
    code: str,
    xq: XueqiuSession,
    llm_base_url: str = DEFAULT_LLM_BASE_URL,
    llm_model: str = DEFAULT_LLM_MODEL,
    llm_api_key: str = "",
    output_dir: str = "results/xueqiu_orders",
    page_delay: float = 1.0,
    no_llm: bool = False,
) -> dict:
    """监控单只股票: 拉取当天讨论 → 过滤 → 总结"""
    symbol = _to_xueqiu_symbol(code)
    log.info(f"=== 监控 {symbol} ===")

    # 1. 拉取当天所有讨论
    raw_posts = fetch_today_discussions(xq, symbol, delay=page_delay)
    if not raw_posts:
        log.info(f"[{symbol}] 今日无讨论数据")
        return {"symbol": symbol, "filtered_posts": [], "summary": ""}

    posts = _parse_posts(raw_posts)
    log.info(f"[{symbol}] 解析后 {len(posts)} 条有效帖子")

    if no_llm:
        # 纯爬取模式: 保存全量帖子, 不过滤不总结
        filtered = posts
        summary = ""
        log.info(f"[{symbol}] no-llm 模式: 保留全部 {len(posts)} 条")
    else:
        # 2. LLM 过滤: 只保留订单/基本面相关
        filtered = llm_filter_posts(posts, llm_base_url, llm_model, llm_api_key)
        if not filtered:
            log.info(f"[{symbol}] LLM 判断今日无订单/基本面相关讨论")
            return {"symbol": symbol, "filtered_posts": [], "summary": ""}

        # 3. LLM 总结
        summary = llm_summarize(filtered, symbol, llm_base_url, llm_model, llm_api_key)

    # 4. 保存结果 (每只股票一个子目录)
    today_str = date.today().strftime("%Y%m%d")
    out_path = Path(output_dir) / symbol
    out_path.mkdir(parents=True, exist_ok=True)

    # 保存 JSON (结构化数据)
    result = {
        "symbol": symbol,
        "date": str(date.today()),
        "scan_time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "total_posts_today": len(posts),
        "filtered_count": len(filtered),
        "filtered_posts": filtered,
        "summary": summary,
    }
    json_path = out_path / f"{today_str}.json"
    with open(json_path, "w", encoding="utf-8") as f:
        json.dump(result, f, ensure_ascii=False, indent=2)

    # 保存 Markdown 总结文档 (仅 LLM 模式)
    if summary:
        md_path = out_path / f"{today_str}.md"
        md_content = (
            f"# {symbol} 订单与基本面信息 ({date.today()})\n\n"
            f"> 数据来源: 雪球讨论 | 今日总讨论 {len(posts)} 条 | "
            f"筛选后 {len(filtered)} 条\n\n"
            f"{summary}\n\n---\n\n"
            f"## 原始筛选帖子\n\n"
        )
        for i, p in enumerate(filtered, 1):
            md_content += (
                f"### [{i}] {p['user']} ({p['created_at']})\n\n"
                f"{p['text'][:1000]}\n\n"
            )
        with open(md_path, "w", encoding="utf-8") as f:
            f.write(md_content)
        log.info(f"总结文档已保存: {md_path}")

    log.info(f"结构化数据已保存: {json_path}")

    # 5. 复制 JSON 到 raw/ 并清理
    try:
        _copy_to_raw(symbol, output_dir, today_str)
    except Exception as e:
        log.warning(f"[{symbol}] raw 复制失败: {e}")

    # 6. 打印摘要
    _print_summary(result)
    return result


def _copy_to_raw(symbol: str, output_dir: str, today_str: str):
    """复制 JSON 到 raw/ 不可变副本，然后删除顶层 JSON"""
    import shutil
    stock_dir = Path(output_dir) / symbol
    raw_dir = stock_dir / "raw"
    raw_dir.mkdir(parents=True, exist_ok=True)

    src_json = stock_dir / f"{today_str}.json"
    dst_json = raw_dir / f"{today_str}.json"
    if src_json.exists():
        shutil.copy2(src_json, dst_json)
        src_json.unlink()
        log.info(f"  ✓ {today_str}.json → raw/ (原文件已删除)")


def _print_summary(result: dict):
    symbol = result["symbol"]
    filtered = result["filtered_posts"]
    summary = result["summary"]

    print(f"\n{'='*60}")
    print(f"  {symbol} 订单/基本面信息监控 ({result['date']})")
    print(f"  今日总讨论: {result['total_posts_today']} | 相关: {len(filtered)}")
    print(f"{'='*60}")

    if summary:
        print(f"\n{summary}\n")
    elif filtered:
        print("\n  [筛选出的帖子]")
        for p in filtered[:10]:
            snippet = p["text"][:80].replace("\n", " ")
            print(f"    {p['user']}: {snippet}...")
    else:
        print("\n  今日无相关订单/基本面讨论。")

    print()


def _load_codes_from_csv(csv_path: str) -> list[str]:
    """从 tushare_stock_basic.csv 读取所有股票的 symbol 列"""
    codes = []
    with open(csv_path, encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            code = (row.get("symbol") or "").strip()
            if code:
                codes.append(code)
    return codes


def main():
    parser = argparse.ArgumentParser(
        description="雪球讨论 — 订单与基本面信息监控 (LLM 筛选+总结)"
    )
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--codes",
                       help="股票代码, 逗号分隔, 如 600519,000858")
    group.add_argument("--stock-csv",
                       help="股票列表 CSV 文件路径 (含 symbol 列), 如 tushare_stock_basic.csv")
    parser.add_argument("--llm-base-url", default=DEFAULT_LLM_BASE_URL,
                        help=f"LLM API base URL (默认: {DEFAULT_LLM_BASE_URL})")
    parser.add_argument("--llm-model", default=DEFAULT_LLM_MODEL,
                        help=f"LLM 模型名 (默认: {DEFAULT_LLM_MODEL})")
    parser.add_argument("--llm-api-key", default="",
                        help="LLM API Key (也可用环境变量 DASHSCOPE_API_KEY 或 OPENAI_API_KEY)")
    parser.add_argument("--output-dir", default="/nvme5/xtang/gp-workspace/gp-data/xueqiu_orders",
                        help="输出根目录 (每只股票一个子目录)")
    parser.add_argument("--delay", type=float, default=3.0,
                        help="每只股票之间的延迟秒数 (防限流, 建议 >= 3)")
    parser.add_argument("--page-delay", type=float, default=2.0,
                        help="翻页延迟秒数")
    parser.add_argument("--skip-no-discussion", action="store_true", default=True,
                        help="跳过无讨论的股票 (不创建空目录)")
    parser.add_argument("--resume", action="store_true", default=False,
                        help="断点续传: 跳过今天已有 JSON 的股票")
    parser.add_argument("--no-llm", action="store_true", default=False,
                        help="纯爬取模式: 不调用 LLM 过滤/总结, 保存全量帖子到 raw/")
    args = parser.parse_args()

    api_key = (
        args.llm_api_key
        or os.environ.get("DASHSCOPE_API_KEY", "")
        or os.environ.get("OPENAI_API_KEY", "")
    )
    if not api_key and not args.no_llm:
        log.error("需要提供 LLM API Key: --llm-api-key 或设置环境变量 DASHSCOPE_API_KEY (或使用 --no-llm)")
        sys.exit(1)

    # 加载股票代码
    if args.stock_csv:
        codes = _load_codes_from_csv(args.stock_csv)
        log.info(f"从 CSV 加载 {len(codes)} 只股票: {args.stock_csv}")
    else:
        codes = [c.strip() for c in args.codes.split(",") if c.strip()]

    if not codes:
        log.error("无股票代码")
        sys.exit(1)

    xq = XueqiuSession()

    today_str = date.today().strftime("%Y%m%d")
    success, skip, fail, resumed = 0, 0, 0, 0
    consecutive_empty = 0  # 连续无数据计数 (WAF 拦截检测)
    WAF_REFRESH_THRESHOLD = 5  # 连续 N 只无数据则刷新会话
    waf_cooldown = 120  # 初始冷却时间, 每次递增
    try:
        for i, code in enumerate(codes):
            if i > 0:
                time.sleep(args.delay)

            # 断点续传: 跳过今天已有 JSON 的股票
            if args.resume:
                sym = _to_xueqiu_symbol(code)
                stock_path = Path(args.output_dir) / sym
                existing_json = stock_path / f"{today_str}.json"
                existing_raw = stock_path / "raw" / f"{today_str}.json"
                if existing_json.exists() or existing_raw.exists():
                    resumed += 1
                    if resumed % 100 == 0:
                        log.info(f"已跳过 {resumed} 只 (今天已处理)")
                    continue

            try:
                result = monitor_stock(
                    code, xq,
                    llm_base_url=args.llm_base_url,
                    llm_model=args.llm_model,
                    llm_api_key=api_key,
                    output_dir=args.output_dir,
                    page_delay=args.page_delay,
                    no_llm=args.no_llm,
                )
                if result.get("filtered_posts"):
                    success += 1
                    consecutive_empty = 0
                    waf_cooldown = 120  # 成功了, 重置冷却时间
                else:
                    skip += 1
                    consecutive_empty += 1
            except Exception as e:
                log.error(f"[{code}] 失败: {e}")
                fail += 1
                consecutive_empty += 1

            # 连续多只无数据 → 可能被 WAF/限流拦截, 主动冷却+刷新
            if consecutive_empty >= WAF_REFRESH_THRESHOLD:
                log.warning(f"连续 {consecutive_empty} 只股票无数据, 可能被限流, 冷却 {waf_cooldown}s ...")
                xq.refresh_session(cooldown=waf_cooldown)
                waf_cooldown = min(waf_cooldown * 2, 600)  # 指数退避, 最长 10 分钟
                consecutive_empty = 0

            # 每 50 只打印进度
            done = i + 1
            if done % 50 == 0 or done == len(codes):
                log.info(f"进度: {done}/{len(codes)} | 有信息: {success} | 无信息: {skip} | 失败: {fail} | 跳过(续传): {resumed}")
    finally:
        xq.close()

    log.info(f"全部完成: {len(codes)} 只股票 | 有信息: {success} | 无信息: {skip} | 失败: {fail} | 跳过(续传): {resumed}")


if __name__ == "__main__":
    main()
